<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ClaudeCodeSpeaketh.ViewModels"
        xmlns:m="using:ClaudeCodeSpeaketh.Models"
        mc:Ignorable="d"
        d:DesignWidth="820" d:DesignHeight="640"
        x:Class="ClaudeCodeSpeaketh.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app.ico"
        Title="ClaudeCodeSpeaketh"
        Width="820" Height="640" MinWidth="640" MinHeight="520"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,*,Auto" Margin="20" RowSpacing="14">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="2">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="ClaudeCodeSpeaketh" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Update.VersionLabel}" FontSize="13"
                               VerticalAlignment="Bottom" Margin="0,0,0,3" Opacity="0.5" />
                </StackPanel>
                <TextBlock Text="Configure how Claude Code reads its responses aloud."
                           FontSize="12" Opacity="0.6" />
            </StackPanel>
        </Grid>

        <!-- Tabs -->
        <TabControl Grid.Row="1">

            <!-- General -->
            <TabItem Header="General">
                <StackPanel Margin="6,12" Spacing="16" MaxWidth="520" HorizontalAlignment="Left">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Spoken responses" FontWeight="SemiBold" />
                        <ToggleSwitch IsChecked="{Binding General.Enabled}"
                                      OnContent="On" OffContent="Off" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Engine" FontWeight="SemiBold" />
                        <RadioButton GroupName="engine"
                                     Content="Neural — Emily etc. (edge-tts): natural, free, needs internet"
                                     IsChecked="{Binding General.UseNeural}" />
                        <RadioButton GroupName="engine"
                                     Content="Classic (SAPI): robotic, but fully offline"
                                     IsChecked="{Binding !General.UseNeural}" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="How much to read per turn" FontWeight="SemiBold" />
                        <CheckBox IsChecked="{Binding General.SpeakEntireResponse}"
                                  Content="Speak the entire response (ALL)" />
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    IsEnabled="{Binding General.MaxCharsEnabled}">
                            <TextBlock Text="Otherwise cap at" VerticalAlignment="Center" />
                            <NumericUpDown Value="{Binding General.MaxCharsValue}"
                                           Minimum="50" Maximum="20000" Increment="50" Width="140" />
                            <TextBlock Text="characters" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Rate (slower … faster)" FontWeight="SemiBold" />
                        <Slider Value="{Binding General.Rate}" Minimum="-10" Maximum="10"
                                TickFrequency="1" IsSnapToTickEnabled="True" Width="360"
                                HorizontalAlignment="Left" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Volume" FontWeight="SemiBold" />
                        <Slider Value="{Binding General.Volume}" Minimum="0" Maximum="100"
                                TickFrequency="10" Width="360" HorizontalAlignment="Left" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Startup" FontWeight="SemiBold" />
                        <CheckBox IsChecked="{Binding General.StartAtStartup}"
                                  Content="Start when I sign in to Windows (hidden in the tray)" />
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Neural (edge-tts) -->
            <TabItem Header="Neural (Emily)">
                <StackPanel Margin="6,12" Spacing="14" MaxWidth="560" HorizontalAlignment="Left">
                    <TextBlock Text="Free neural voices via edge-tts (Microsoft Edge). Includes the Irish female voice Emily. Needs Python + internet."
                               Opacity="0.7" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Install neural voices"
                                Command="{Binding Neural.InstallCommand}"
                                IsEnabled="{Binding !Neural.IsBusy}"
                                IsVisible="{Binding !Neural.IsAvailable}"
                                Background="#3aa55d" Foreground="White" Padding="12,8" />
                        <Button Content="↻ Refresh"
                                Command="{Binding Neural.RefreshCommand}"
                                IsEnabled="{Binding !Neural.IsBusy}" Padding="12,8" />
                    </StackPanel>
                    <ComboBox ItemsSource="{Binding Neural.Voices}"
                              SelectedItem="{Binding Neural.SelectedVoice, Mode=TwoWay}"
                              IsEnabled="{Binding Neural.IsAvailable}"
                              Width="520" HorizontalAlignment="Left">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="m:EdgeVoiceInfo">
                                <TextBlock Text="{Binding Display}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="▶ Preview"
                            Command="{Binding Neural.PreviewCommand}"
                            IsEnabled="{Binding Neural.IsAvailable}" />
                    <ProgressBar IsIndeterminate="True" IsVisible="{Binding Neural.IsBusy}"
                                 Height="6" HorizontalAlignment="Stretch" />
                    <TextBlock Text="{Binding Neural.Status}" FontSize="12" Opacity="0.75" TextWrapping="Wrap" />
                </StackPanel>
            </TabItem>

            <!-- SAPI Voices -->
            <TabItem Header="SAPI Voices">
                <StackPanel Margin="6,12" Spacing="14" MaxWidth="560" HorizontalAlignment="Left">
                    <TextBlock Text="Pick the Windows voice the hook speaks with."
                               Opacity="0.7" />
                    <ComboBox ItemsSource="{Binding Sapi.Voices}"
                              SelectedItem="{Binding Sapi.SelectedVoice, Mode=TwoWay}"
                              Width="520" HorizontalAlignment="Left">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="m:SapiVoiceInfo">
                                <TextBlock Text="{Binding Display}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="▶ Preview" Command="{Binding Sapi.PreviewCommand}" />
                        <Button Content="■ Stop" Command="{Binding Sapi.StopPreviewCommand}" />
                    </StackPanel>
                    <TextBlock Text="Picking a voice auditions it immediately. en-GB voices (Hazel/Susan) are British; add the Irish 'Orla' voice from the Get Voices tab."
                               FontSize="11" Opacity="0.5" TextWrapping="Wrap" />
                </StackPanel>
            </TabItem>

            <!-- Get Voices -->
            <TabItem Header="Get Voices">
                <StackPanel Margin="6,12" Spacing="14" MaxWidth="600" HorizontalAlignment="Left">
                    <TextBlock Text="Irish English voice (Orla)" FontWeight="SemiBold" />
                    <TextBlock Text="Installs the Windows en-IE text-to-speech voice as a Feature on Demand. Needs admin (one UAC prompt) and a download. Once installed it appears in the SAPI Voices tab automatically."
                               FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Get Irish voice (Orla)"
                                Command="{Binding Voices.InstallIrishCommand}"
                                IsEnabled="{Binding !Voices.IsBusy}"
                                Background="#3aa55d" Foreground="White" Padding="14,8" />
                        <Button Content="↻ Refresh voices"
                                Command="{Binding Voices.RefreshVoicesCommand}"
                                IsEnabled="{Binding !Voices.IsBusy}" Padding="12,8" />
                    </StackPanel>
                    <ProgressBar Minimum="0" Maximum="100"
                                 Value="{Binding Voices.InstallPercent}"
                                 IsIndeterminate="{Binding Voices.InstallIndeterminate}"
                                 IsVisible="{Binding Voices.IsBusy}"
                                 ShowProgressText="True" Height="18" HorizontalAlignment="Stretch" />
                    <TextBlock Text="{Binding Voices.Status}" FontSize="12" Opacity="0.75" TextWrapping="Wrap" />
                </StackPanel>
            </TabItem>

            <!-- Sessions -->
            <TabItem Header="Sessions">
                <StackPanel Margin="6,12" Spacing="10" MaxWidth="560" HorizontalAlignment="Left">
                    <DockPanel>
                        <Button Content="↻ Refresh" DockPanel.Dock="Right"
                                Command="{Binding Sessions.RefreshCommand}" Padding="8,4" />
                        <TextBlock Text="{Binding Sessions.Hint}" Opacity="0.7" TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                    <ScrollViewer MaxHeight="380" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Sessions.Sessions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SessionToggle">
                                    <StackPanel Margin="0,3">
                                        <CheckBox IsChecked="{Binding Enabled}" Content="{Binding Display}"
                                                  FontFamily="Consolas, Courier New" />
                                        <TextBlock Text="{Binding Detail}" FontSize="11" Opacity="0.5"
                                                   TextWrapping="Wrap" Margin="28,0,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </TabItem>

            <!-- Karaoke -->
            <TabItem Header="Karaoke">
                <StackPanel Margin="6,12" Spacing="14" MaxWidth="560" HorizontalAlignment="Left">
                    <CheckBox IsChecked="{Binding Karaoke.Enabled}"
                              Content="Show the karaoke window (highlights each word as it is spoken)" />
                    <TextBlock Text="Active only with the resident app running and the Neural engine selected."
                               FontSize="11" Opacity="0.5" TextWrapping="Wrap" />
                    <StackPanel Spacing="6">
                        <TextBlock Text="Highlight colour" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox Text="{Binding Karaoke.ColorHex}" Width="130" />
                            <Button Content="Amber" Command="{Binding Karaoke.SetColorCommand}" CommandParameter="#FFD54A" />
                            <Button Content="Cyan"  Command="{Binding Karaoke.SetColorCommand}" CommandParameter="#4ADEDE" />
                            <Button Content="Pink"  Command="{Binding Karaoke.SetColorCommand}" CommandParameter="#FF6FB5" />
                            <Button Content="Green" Command="{Binding Karaoke.SetColorCommand}" CommandParameter="#7CE38B" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Text size" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Slider Value="{Binding Karaoke.FontSize}" Minimum="14" Maximum="64"
                                    TickFrequency="2" IsSnapToTickEnabled="True" Width="300" />
                            <TextBlock Text="{Binding Karaoke.FontSize}" VerticalAlignment="Center" Width="30" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Position on screen" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding Karaoke.Positions}"
                                  SelectedItem="{Binding Karaoke.Position, Mode=TwoWay}" Width="160" />
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Hook -->
            <TabItem Header="Hook">
                <StackPanel Margin="6,12" Spacing="14" MaxWidth="560" HorizontalAlignment="Left">
                    <TextBlock Text="Claude Code Stop hook" FontWeight="SemiBold" />
                    <TextBlock Text="Installs/removes the hook in ~/.claude/settings.json that makes Claude Code speak its responses. Your other hooks and settings are left untouched."
                               FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Install hook"
                                Command="{Binding Hook.InstallCommand}"
                                IsEnabled="{Binding !Hook.IsInstalled}"
                                Background="#3aa55d" Foreground="White" Padding="14,8" />
                        <Button Content="Uninstall hook"
                                Command="{Binding Hook.UninstallCommand}"
                                IsEnabled="{Binding Hook.IsInstalled}" Padding="14,8" />
                        <Button Content="Re-deploy scripts"
                                Command="{Binding Hook.RedeployScriptsCommand}" Padding="14,8" />
                    </StackPanel>
                    <TextBlock Text="{Binding Hook.Status}" FontSize="12" Opacity="0.75" TextWrapping="Wrap" />
                </StackPanel>
            </TabItem>

            <!-- Updates -->
            <TabItem Header="Updates">
                <StackPanel Margin="6,12" Spacing="14" MaxWidth="560" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding Update.VersionLabel, StringFormat='Installed version: {0}'}"
                               FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Check for updates"
                                Command="{Binding Update.CheckCommand}"
                                IsEnabled="{Binding !Update.IsBusy}" Padding="12,8" />
                        <Button Content="Download &amp; install"
                                Command="{Binding Update.DownloadAndApplyCommand}"
                                IsEnabled="{Binding !Update.IsBusy}"
                                Background="#5d63ff" Foreground="White" Padding="12,8" />
                    </StackPanel>
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding Update.DownloadPercent}"
                                 IsVisible="{Binding Update.ShowProgress}"
                                 ShowProgressText="True" Height="18" HorizontalAlignment="Stretch" />
                    <TextBlock Text="{Binding Update.Status}" FontSize="12" Opacity="0.75" TextWrapping="Wrap" />

                    <TextBlock Text="What's new" FontWeight="SemiBold" Margin="0,6,0,0" />
                    <Border BorderBrush="#33000000" BorderThickness="1" CornerRadius="4"
                            Height="240" HorizontalAlignment="Stretch">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,8">
                            <SelectableTextBlock Text="{Binding Update.Changelog}"
                                                 FontSize="12" TextWrapping="Wrap"
                                                 FontFamily="Cascadia Code, Consolas, monospace" />
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </TabItem>

        </TabControl>

        <!-- Footer: save + status -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <TextBlock Grid.Column="0" Text="{Binding Status}"
                       VerticalAlignment="Center" TextWrapping="Wrap"
                       FontSize="12" Opacity="0.75" />
            <Button Grid.Column="1" Content="Save"
                    Command="{Binding SaveCommand}"
                    Background="#5d63ff" Foreground="White" Padding="20,8" />
        </Grid>
    </Grid>
</Window>
