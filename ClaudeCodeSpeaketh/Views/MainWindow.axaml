<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ClaudeCodeSpeaketh.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="820" d:DesignHeight="640"
        x:Class="ClaudeCodeSpeaketh.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ClaudeCodeSpeaketh"
        Width="820" Height="640" MinWidth="640" MinHeight="520"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="24" Spacing="6" VerticalAlignment="Top">
        <TextBlock Text="{Binding Heading}" FontSize="24" FontWeight="SemiBold" />
        <TextBlock Text="{Binding Subheading}" FontSize="13" Opacity="0.6" />
    </StackPanel>

</Window>
